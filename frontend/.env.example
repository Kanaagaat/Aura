# Frontend environment (copy to .env.local)
# Leave VITE_API_URL empty in dev to use Vite proxy (/api → :8000)
VITE_API_URL=
VITE_API_BASE_URL=

# Google Sign-In (Web client from Google Cloud Console)
# Must match GOOGLE_CLIENT_ID on the backend. Authorized origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# Pre-launch production mode.
# Vite only exposes env vars prefixed with VITE_ to client code.
# Set VITE_PUBLIC_LAUNCH=false in production to show only the landing/waitlist.
# Open /app?preview_secret=<value> once to unlock the hidden app for the current browser session.
VITE_PUBLIC_LAUNCH=false
VITE_PREVIEW_SECRET=change-me-before-deploy

# Supabase waitlist storage.
VITE_SUPABASE_URL=https://nkyulfgyxewpthzbbdoh.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
